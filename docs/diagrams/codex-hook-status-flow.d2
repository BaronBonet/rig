vars: {
  d2-config: {
    layout-engine: elk
    sketch: true
  }
}
direction: right

***: {
  style: {
    border-radius: 5
    stroke-width: 3
  }
}

tmux: {
  label: "tmux task session"
  direction: down
  style: {
    fill: "#59493f"
    stroke: "#ef9f76"
    font-color: white
  }

  codex: {
    label: "Codex CLI"
    sublabel: "SessionStart\nUserPromptSubmit\nPreToolUse\nPermissionRequest\nPostToolUse\nStop"
    style: {
      fill: "#4a2f45"
      stroke: "#f4b8e4"
      font-color: white
    }
  }

  hooks_json: {
    label: "hooks.json"
    sublabel: "command hook rules"
    style: {
      fill: "#4a2f45"
      stroke: "#f4b8e4"
      font-color: white
    }
  }

  forwarder: {
    label: "forward-to-rig.sh"
    sublabel: "POST raw JSON payload"
    style: {
      fill: "#4a2f45"
      stroke: "#f4b8e4"
      font-color: white
    }
  }
}

daemon: {
  label: "Task daemon"
  direction: down
  style: {
    fill: "#2a2e42"
    stroke: "#a6d189"
    font-color: white
  }

  http: {
    label: "HTTP hook server"
    sublabel: "loopback only\nsecret header"
    style: {
      fill: "#485e30"
      stroke: "#a6d189"
      font-color: white
    }
  }

  decoder: {
    label: "Codex hook handler"
    sublabel: "DecodeHookEventInput"
    style: {
      fill: "#485e30"
      stroke: "#a6d189"
      font-color: white
    }
  }

  service: {
    label: "HandleHookEvent"
    sublabel: "resolve task\npersist read models\nmap status"
    style: {
      fill: "#485e30"
      stroke: "#a6d189"
      font-color: white
    }
  }

  socket: {
    label: "Socket subscription"
    sublabel: "task_status_update envelopes"
    style: {
      fill: "#485e30"
      stroke: "#a6d189"
      font-color: white
    }
  }
}

sqlite: {
  label: "SQLite"
  direction: down
  style: {
    fill: "#1a1b2e"
    stroke: "#babbf1"
    font-color: white
  }

  sessions: {
    label: "task_provider_sessions"
    shape: sql_table
    provider_session_id: text
    transcript_path: text
    model: text
    cwd: text
  }

  resume: {
    label: "task_resume_metadata"
    shape: sql_table
    session_id: text
  }

  activity: {
    label: "task_activity"
    shape: sql_table
    role: "user | assistant"
    text: text
  }

  status: {
    label: "task_status"
    shape: sql_table
    phase: "starting | working | waiting_for_input | stopped"
    raw_event_name: text
  }
}

tui: {
  label: "TUI"
  sublabel: "updates row status,\nactivity, token usage"
  style: {
    fill: "#3b4261"
    stroke: "#8caaee"
    font-color: white
  }
}

tmux.codex -> tmux.hooks_json: "1. Event matches\nRig hook rule" {
  style: {
    stroke: "#f4b8e4"
    stroke-width: 3
    animated: true
  }
}
tmux.hooks_json -> tmux.forwarder: "2. Run shell command\nwith event name" {
  style: {
    stroke: "#f4b8e4"
    stroke-width: 3
    animated: true
  }
}
tmux.forwarder -> daemon.http: "3. POST /codex-hook\nX-Codex-Hook-Event\nX-Rig-Hook-Secret" {
  style: {
    stroke: "#f4b8e4"
    stroke-width: 3
    animated: true
  }
}
daemon.http -> daemon.decoder: "4. authorize and decode" {
  style: {
    stroke: "#a6d189"
    stroke-width: 3
    animated: true
  }
}
daemon.decoder -> daemon.service: "5. HookEventInput" {
  style: {
    stroke: "#a6d189"
    stroke-width: 3
    animated: true
  }
}
daemon.service -> sqlite.sessions: "6. upsert session" {
  style: {
    stroke: "#e5c890"
    stroke-width: 5
    animated: true
  }
}
daemon.service -> sqlite.resume: "7. upsert resume metadata" {
  style: {
    stroke: "#e5c890"
    stroke-width: 5
    animated: true
  }
}
daemon.service -> sqlite.activity: "8. insert compact activity" {
  style: {
    stroke: "#e5c890"
    stroke-width: 5
    animated: true
  }
}
daemon.service -> sqlite.status: "9. upsert latest status" {
  style: {
    stroke: "#e5c890"
    stroke-width: 5
    animated: true
  }
}
sqlite.status -> daemon.socket: "10. in-process subscriber fanout" {
  style: {
    stroke: "#a6d189"
    stroke-width: 3
    animated: true
  }
}
daemon.socket -> tui: "11. stream task_status_update" {
  style: {
    stroke: "#8caaee"
    stroke-width: 3
    animated: true
  }
}
