#!/bin/sh
set -eu

collector_url=${CODEX_HOOK_COLLECTOR_URL:-http://127.0.0.1:4123/hook}
agent_exec={{ .AgentExecQuoted }}
agent_source_root={{ .SourceRootQuoted }}
event_name=$1
payload_file=$(mktemp "${TMPDIR:-/tmp}/codex-hook.XXXXXX")
trap 'rm -f "$payload_file"' EXIT INT TERM

cat >"$payload_file"

if command -v curl >/dev/null 2>&1 && curl -fsS --max-time 2 -X POST -H "Content-Type: application/json" -H "X-Codex-Hook-Event: $event_name" --data-binary @"$payload_file" "$collector_url"; then
  exit 0
fi
if command -v agent >/dev/null 2>&1; then
  agent observer ingest "$event_name" <"$payload_file"
  exit $?
fi
if [ -n "$agent_exec" ] && [ -x "$agent_exec" ]; then
  "$agent_exec" observer ingest "$event_name" <"$payload_file"
  exit $?
fi
if command -v go >/dev/null 2>&1 && [ -f "$agent_source_root/go.mod" ]; then
  cd "$agent_source_root" && go run ./cmd/agent observer ingest "$event_name" <"$payload_file"
  exit $?
fi
exit 0
