{
  "name": "rig-release-tooling",
  "private": true,
  "packageManager": "npm@11.12.1",
  "engines": {
    "node": "^24.10.0 || ^25.0.0",
    "npm": "^11.12.1"
  },
  "scripts": {
    "commitlint:stdin": "commitlint",
